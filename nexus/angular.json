{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "nexus": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/nexus",
      "sourceRoot": "projects/nexus/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/nexus/src/main.ts",
            "tsConfig": "projects/nexus/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/nexus/public"
              }
            ],
            "styles": [
              "projects/nexus/src/material-theme.scss",
              "projects/nexus/src/styles.css",
              "projects/user-registration/assets/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "nexus:build:production"
            },
            "development": {
              "buildTarget": "nexus:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "user-registration": {
      "projectType": "library",
      "root": "projects/user-registration",
      "sourceRoot": "projects/user-registration/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/user-registration/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/user-registration/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/user-registration/tsconfig.spec.json"
          }
        }
      }
    },
