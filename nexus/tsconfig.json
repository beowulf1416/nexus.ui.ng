{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "accounting": ["./dist/accounting"],
      "admin-tenants": ["./dist/admin-tenants"],
      "admin-users": ["./dist/admin-users"],
      "cms": ["./dist/cms"],
      // "auth": ["./dist/auth"],
      // "common": ["./dist/common"],
      "core": ["./dist/core"],
      "crm": ["./dist/crm"],
      "documents": ["./dist/documents"],
